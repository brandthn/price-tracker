GCP_PROJECT_ID=pa-open-prices
GCP_REGION=europe-west9
BQ_DATASET=open_prices_dw
# Localisation BigQuery du dataset (souvent EU pour l’Europe)
BQ_LOCATION=EU

GCS_BRONZE_BUCKET=pa-open-prices-bronze
GCS_SIGNALS_BUCKET=pa-open-prices-signals
GCS_ARTIFACTS_BUCKET=pa-open-prices-artifacts

ARTIFACT_REPOSITORY=open-prices

# Bronze local (worker ingestion)
RAW_DATA_PATH=./raw
# true pour rejouer le nettoyage sans retélécharger Hugging Face
SKIP_DOWNLOAD=false
# Limite de lignes Parquet traitées (vide = tout le fichier ; utile en dev)
# INGEST_MAX_ROWS=50000
# Limite d’EAN interrogés côté OFF (vide = tous les manquants détectés)
# OFF_MAX_PRODUCTS=200

# Date logique du run (Cloud Scheduler) ; vide = jour UTC courant
# EXECUTION_DATE=2026-05-12

HF_DATASET=openfoodfacts/open-prices
HF_VIEW=prices
HF_FILE_FORMAT=parquet

OPENFOODFACTS_API_BASE=https://world.openfoodfacts.org/api/v2/product

ALLOWED_COUNTRIES=FR,GP,GF,MQ,RE,YT,PM,MF,BL,WF,NC,PF
ALLOWED_CURRENCIES=EUR
ALLOWED_PROOF_TYPES=RECEIPT,PRICE_TAG,PRICETAG

MIN_PRICE_EUR=0.01
MAX_PRICE_EUR=500.00

QUALITY_GATE_ACCEPTANCE_RATE=0.60
QUALITY_GATE_STORE_COVERAGE=0.70
QUALITY_GATE_EAN_RESOLUTION=0.80
MIN_OBSERVATIONS_FOR_INDEX=3

SIGNAL_MAX_WAIT_SECONDS=600
SIGNAL_POLL_INTERVAL_SECONDS=15

WORKER_TIMEOUT_SECONDS=900
LOG_LEVEL=INFO
ENVIRONMENT=dev

# Optionnel : attendre un signal amont nommé (fichier ou GCS) avant ingestion
# UPSTREAM_WORKER=some_other_job
